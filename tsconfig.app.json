{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "paths": {
      "@anvilkit/puck-studio": ["./src/index.ts"],
      "@anvilkit/puck-studio/legacy": ["./src/index.legacy.ts"],
      "@anvilkit/puck-studio/overrides": ["./src/core/overrides/index.tsx"],
      "@anvilkit/puck-studio/styles.css": ["./src/styles.css"],
      "@/*": ["./src/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["app", "next-env.d.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
